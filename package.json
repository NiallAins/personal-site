{
    "name": "personalsite",
    "main": "main.js",
     "scripts": {
        "dev": "npm run build && npm run build-watch",
        "build": "npm run build-style && npm run build-script",
        "build-style": "node ./build-scripts/scss-to-ts && sass ./styles/index.scss > ./dist/style.css",
        "build-script": "webpack --config ./build-scripts/webpack.config.js --mode development",
        "build-script-prod": "sed -i -e 's/PROD = false/PROD = true/' ./scripts/_debug.ts && webpack --config ./build-scripts/webpack.config.js --mode production",
        "build-watch": "bash ./build-scripts/watch.sh",
        "push": "bash ./build-scripts/push.sh",
        "deploy": "bash ./build-scripts/deploy.sh"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/NiallAins/personal-site.git"
    },
    "license": "ISC",
    "homepage": "https://github.com/NiallAins/personal-site#readme",
    "devDependencies": {
        "concurrently": "^9.2.1",
        "http-server": "^14.1.1",
        "onchange": "^7.1.0",
        "sass": "^1.100.0",
        "ts-loader": "^9.5.7",
        "typescript": "^6.0.3",
        "webpack": "^5.107.2",
        "webpack-cli": "^7.0.2"
    }
}
